{
  "name": "magane",
  "version": "2.0.0",
  "description": "A lie about a lie... It turns inside-out on itself.",
  "author": "Pitu <7425261+Pitu@users.noreply.github.com>",
  "contributors": [
    {
      "name": "iCrawl",
      "email": "icrawltogo@gmail.com"
    }
  ],
  "license": "MIT",
  "private": false,
  "scripts": {
    "dev": "cross-env NODE_ENV=development webpack-dev-server --open --hot",
    "build": "cross-env NODE_ENV=production webpack --progress --hide-modules"
  },
  "dependencies": {
    "vue": "^2.4.4",
    "vue-scrollto": "^2.8.0",
    "vuebar": "^0.0.17"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 8"
  ],
  "devDependencies": {
    "babel-core": "^6.26.0",
    "babel-eslint": "^9.0.0",
    "babel-loader": "^7.1.2",
    "babel-plugin-transform-regenerator": "^6.26.0",
    "babel-polyfill": "^6.26.0",
    "babel-preset-env": "^1.6.0",
    "babel-preset-stage-3": "^6.24.1",
    "cross-env": "^5.0.5",
    "css-loader": "^0.28.7",
    "eslint": "^5.12.0",
    "eslint-config-aqua": "^4.4.1",
    "eslint-plugin-vue": "^5.1.0",
    "file-loader": "^1.1.4",
    "node-sass": "^4.5.3",
    "sass-loader": "^6.0.6",
    "vue-loader": "^13.0.5",
    "vue-template-compiler": "^2.4.4",
    "webpack": "^3.6.0",
    "webpack-dev-server": "^2.9.1"
  },
  "eslintConfig": {
    "parserOptions": {
      "ecmaVersion": 8
    },
    "extends": [
      "aqua",
      "plugin:vue/recommended"
    ],
    "env": {
      "browser": true,
      "node": true
    },
    "rules": {
      "camelcase": 0,
      "capitalized-comments": 0,
      "func-names": 0,
      "id-length": 0,
      "no-console": 0,
      "no-new": 0,
      "no-unused-expressions": 0,
      "quotes": [
        "error",
        "single"
      ]
    },
    "overrides": {
      "files": [
        "src/bd-template.js"
      ],
      "rules": {
        "spaced-comment": 0
      }
    }
  },
  "eslintIgnore": [
    "magane.plugin.js"
  ]
}
